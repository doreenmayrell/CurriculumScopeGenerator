# Copy this file to ".env" and fill in the values.
# Used by the Scope Result "Export to Google Doc" button.
# Setup steps: docs/google-docs-export.md
VITE_GOOGLE_CLIENT_ID=

# Drive folder every exported doc is created in. This defaults in code to:
# https://drive.google.com/drive/folders/1NSZfxPSnE-y9Oab_K9XMX2QQVMGKk1l7
# Override only if you want a different folder.
VITE_GOOGLE_DRIVE_FOLDER_ID=1NSZfxPSnE-y9Oab_K9XMX2QQVMGKk1l7

# Anthropic API key for real Run Scope calls — SERVER-SIDE ONLY (no VITE_ prefix).
ANTHROPIC_API_KEY=
